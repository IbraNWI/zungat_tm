APP_PORT=8000
APP_IPV4_ADDRESS=192.168.10.10
APP_NETWORK_SUBNET=192.168.10.0/24

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=test.ntwrk.ing,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://test.ntwrk.ing,https://test.ntwrk.ing:4439
DJANGO_SECURE_PROXY_SSL_HEADER=True
DJANGO_TIME_ZONE=Europe/Moscow
DJANGO_SQLITE_PATH=/app/data/db.sqlite3
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/app/media

DJANGO_RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1

# Optional first admin account. Remove these lines after the first successful start.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
